# Docker image settings
KDB_BASE_IMAGE=kdb-insights-core:latest
KDB_IMAGE=model-trading-bot-kdb:local
BACKEND_IMAGE=model-trading-bot-backend:local
FRONTEND_IMAGE=model-trading-bot-frontend:local

# Local path containing kc.lic, kx.lic, or k4.lic
QLIC=./qlic

# Backend settings
DEFAULT_SYMBOLS=AAPL,AMZN,META,NFLX,GOOGL
DATA_PROVIDER=yfinance
STORAGE_BACKEND=kdb
KDB_HOST=kdb
KDB_PORT=5000
LOCAL_DATA_DIR=/app/data
SHARED_AUTH_DB=/shared-auth/auth.db
SHARED_AUTH_DIR=./data/shared-auth
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_DAYS=30
AUTH_ALLOW_LEGACY_PASSWORD_CLAIM=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://modeltradingbot.lan
BOOTSTRAP_ON_STARTUP=true
AUTO_INGEST_ON_EMPTY=true
SP500_REFRESH_HOURS=24
UNIVERSE_REFRESH_ON_STARTUP=true
